{
  "name": "@necklace/wallet-core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "TS port of Pearl's Schnorr/Taproot key-path crypto path: bech32m, WIF base58check, BIP-341 sighash, BIP-340 signing. Pinned to the repo's real KATs in ./fixtures. Filled in by the crypto agent.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": ["src", "fixtures"],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "build": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "@necklace/shared": "workspace:*",
    "@noble/curves": "^2.0.0",
    "@noble/hashes": "^2.0.0",
    "@scure/base": "^2.0.0",
    "@scure/bip32": "^2.0.0",
    "@scure/bip39": "^2.0.0",
    "@scure/btc-signer": "^2.0.0"
  },
  "devDependencies": {
    "@necklace/eslint-config": "workspace:*",
    "typescript": "^6.0.0",
    "vitest": "^4.0.0"
  }
}
