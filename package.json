{
  "name": "necklace-wallet",
  "version": "0.1.0",
  "private": true,
  "description": "Necklace — an open-source, non-custodial Chrome (MV3) wallet for Pearl (PRL).",
  "license": "GPL-3.0-or-later",
  "homepage": "https://github.com/xxgvqxx/necklace-wallet",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xxgvqxx/necklace-wallet.git"
  },
  "packageManager": "pnpm@10.22.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "pnpm -r --if-present run lint",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "pnpm -r --if-present run test",
    "build": "pnpm --filter @necklace/extension run build",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "@necklace/eslint-config": "workspace:*",
    "@types/node": "22.19.19",
    "eslint": "10.4.1",
    "prettier": "3.8.3",
    "typescript": "6.0.3"
  }
}
