{
  "name": "@necklace/extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Necklace — Chrome MV3 non-custodial Pearl (PRL) wallet. All signing happens locally; only signed raw tx hex is sent to the API.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "vitest run"
  },
  "dependencies": {
    "@necklace/shared": "workspace:*",
    "@necklace/wallet-core": "workspace:*",
    "qrcode-generator": "2.0.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@necklace/eslint-config": "workspace:*",
    "@types/chrome": "^0.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  }
}
